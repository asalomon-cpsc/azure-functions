              "type": "Microsoft.Web/sites/config",
              "apiVersion": "2022-09-01",
              "name": "[format('{0}/{1}', parameters('functionAppName'), 'appsettings')]",
              "properties": "[union(reference(resourceId('Microsoft.Web/sites/config', parameters('functionAppName'), 'appsettings'), '2022-09-01').properties, variables('managedIdentityEmailSettings'), variables('optionalDashboardSetting'))]"
