              "EMAIL_SUBJECT": "[parameters('emailSubject')]",
              "EMAIL_RECIPIENTS": "[parameters('emailRecipients')]",
              "ACS_ENDPOINT": "[parameters('acsEndpoint')]"
            },
            "optionalDashboardSetting": "[if(empty(parameters('dashboardUrl')), createObject(), createObject('dashboard_url', parameters('dashboardUrl')))]"
          },
